# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/clinic_db?schema=public"

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Facebook Messenger
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FB_VERIFY_TOKEN=your_facebook_verify_token
FB_APP_SECRET=your_facebook_app_secret

# Instagram
IG_ACCESS_TOKEN=your_instagram_access_token
IG_VERIFY_TOKEN=your_instagram_verify_token

# ManyChat
MANYCHAT_WEBHOOK_TOKEN=your_manychat_webhook_secret

# Clinic WhatsApp Number (for redirect from FB/IG)
CLINIC_WHATSAPP_NUMBER=966XXXXXXXXX
